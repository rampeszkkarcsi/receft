[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Gyümölcskrémes",
        "recipeIngredient": [
            "Piskótalap",
            "6 tojás",
            "12 dkg cukor",
            "12 dkg liszt",
            "Krém",
            "7 dl tej",
            "1 csomag vaníliás cukor",
            "10 dkg cukor",
            "6 dkg liszt",
            "4 tojássárgája + a fehérje",
            "1/2 csomag vaníliás pudingpor"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A tojásfehérjéből kemény habot verünk."
            },
            {
                "@type": "HowToStep",
                "text": "A tojássárgáját összekeverjük a cukorral, majd óvatosan belekeverjük a habba."
            },
            {
                "@type": "HowToStep",
                "text": "Végül lazán hozzáadjuk a lisztet."
            },
            {
                "@type": "HowToStep",
                "text": "Kivajazott, lisztezett tepsiben 170 °C-on kb. 14 perc alatt megsütjük."
            },
            {
                "@type": "HowToStep",
                "text": "6 dl tejet a vaníliás cukorral és a cukorral felforralunk."
            },
            {
                "@type": "HowToStep",
                "text": "Közben a tojássárgáját kikeverjük a pudingporral, a liszttel és 1 dl tejjel."
            },
            {
                "@type": "HowToStep",
                "text": "Ráöntjük a felforrt tejet, majd kis lángon, állandó keverés mellett sűrűre főzzük."
            },
            {
                "@type": "HowToStep",
                "text": "Ha kissé kihűlt, rákenjük a gyümölccsel megszórt piskótalapra."
            },
            {
                "@type": "HowToStep",
                "text": "A megmaradt tojásfehérjéből kemény habot verünk, és a forró krémbe keverjük."
            }
        ],
