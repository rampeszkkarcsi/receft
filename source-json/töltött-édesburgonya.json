        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Az édesburgonyát alaposan megmosom, megszurkálom és mikróban sütöm. (max. teljesítményen 5-5 perc mindkét oldal)."
            },
            {
                "@type": "HowToStep",
                "text": "Közben egy kis fej lilahagymát apróra vágok, olajon megdinsztelem, rá a zúzott fokhagymát, majd az apróra kockázott csirkemellet."
            },
            {
                "@type": "HowToStep",
                "text": "Sózzom, borsozom jól megpirítom."
            },
            {
                "@type": "HowToStep",
                "text": "Ráteszem a felaprított paradicsomot, vagy aszalt paradicsomot, bazsalikomot."
            },
            {
                "@type": "HowToStep",
                "text": "Kicsit összesütöm."
            },
            {
                "@type": "HowToStep",
                "text": "A édesburgonyát félbevágom, kicsit megkaparom, hogy mélyedés legyen a tölteléknek."
            },
            {
                "@type": "HowToStep",
                "text": "Ráteszem a ragut, tetejére reszelt sajtot, vagy fetát és mehet a sütőbe."
            },
            {
                "@type": "HowToStep",
                "text": "170-180°C-on amíg megpirul a teteje."
            }
        ],
