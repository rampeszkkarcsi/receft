[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "CSIRKEMELL PARADICSOMOS SPÁRGÁVAL",
        "recipeIngredient": [
            "4 bőrös fél csirkemell",
            "8 szál kakukkfű",
            "só",
            "50 dkg zöld és fehér spárga",
            "20 dkg koktélparadicsom",
            "1 dl olívaolaj",
            "2 ek. balzsamecet",
            "frissen őrölt feketebors",
            "5 dkg hideg vaj"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A spárgát megpucoljuk és félbevágjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A paradicsomot megmossuk és félbevágjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A csirkemellet besózzuk és bedörzsöljük kakukkfűlevelekkel."
            },
            {
                "@type": "HowToStep",
                "text": "A csirkemellet a bőrös felén, kevés olívaolajon elősütjük, majd 160 fokos sütőben 25 perc alatt készre sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Ezalatt elkészítjük a köretet."
            },
            {
                "@type": "HowToStep",
                "text": "Serpenyőben olajat melegítünk, és beletesszük a spárgát."
            },
            {
                "@type": "HowToStep",
                "text": "Közepes lángon, rázogatva 10 percig sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Hozzádobjuk a paradicsomot, sózzuk, borsozzuk és 5 perc után meglocsoljuk a balzsamecettel."
            },
            {
                "@type": "HowToStep",
                "text": "A tűzről lehúzva a hideg vajat hozzáadjuk, és ezzel sűrítjük a mártást."
            },
            {
                "@type": "HowToStep",
                "text": "A csirkemellet felszeletelve, a spárgás paradicsommal tálaljuk."
            }
        ],
