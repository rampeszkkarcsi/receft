        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A burgonyát héjában megfőzzük, meghámozzuk, kettévágjuk, és közepét kivájjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A túrót és a kivágott darabkákat áttörjük, és kikeverjük a kefirrel."
            },
            {
                "@type": "HowToStep",
                "text": "Ízesítjük a finomra vágott hagymával, petrezselyemmel, bazsalikommal és sóval."
            },
            {
                "@type": "HowToStep",
                "text": "A masszát visszatöltjük a burgonyába."
            },
            {
                "@type": "HowToStep",
                "text": "Tetejükre reszelt sajtot halmozunk"
            },
            {
                "@type": "HowToStep",
                "text": "Olajozott tepsibe egymás mellé tesszük."
            },
            {
                "@type": "HowToStep",
                "text": "10-15 percig előmelegített sütőben sütjük."
            }
        ],
