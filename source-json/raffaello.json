        "name": "Raffaello",
        "recipeIngredient": [
            "25 dg Rama",
            "30 dg porcukor",
            "30 dg kókuszreszelék",
            "30 dg tejpor",
            "1,5 dl víz"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A vizet a cukorral 3-4 percig fözzük, beletesszük a Rámát, ha elolvadt, akkor a tejport adjuk hozzá, a végén belekeverjük a kókuszreszeléket."
            },
            {
                "@type": "HowToStep",
                "text": "3-4 órát állni hagyjuk a hütöben, amíg meg nem keményedik."
            },
            {
                "@type": "HowToStep",
                "text": "Vizes kézzel golyókat formálunk. A közepébe mandulát, mogyorót, vagy diót tehetünk."
            },
            {
                "@type": "HowToStep",
                "text": "Végül kókuszreszelékben megforgatjuk."
            }
        ],
