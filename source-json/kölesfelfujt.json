[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Kölesfelfujt",
        "recipeIngredient": [
            "15 dkg köles",
            "6 dl 1/5 %-os tej",
            "2 tojássárgája",
            "2 tojás fehérje kemény habbá verve",
            "2 evőkanál méz",
            "1 citrom reszelt héja",
            "3 dkg mazsola vagy vörös áfonya 15 percre rumba áztatva",
            "1 kávéskanál vaníliaaroma",
            "csipetnyi só",
            "leheletnyi fahéj"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A kölest mosd meg, majd a tejben egy csipet sóval tedd fel főni."
            },
            {
                "@type": "HowToStep",
                "text": "Alacsony hőfokon főzd, mert legalább 20 mire a köles megpuhul."
            },
            {
                "@type": "HowToStep",
                "text": "Gyakran kevergesd, nehogy leégjen."
            },
            {
                "@type": "HowToStep",
                "text": "Közben a tojás fehérjét, egy csipetnyi sóval, verd fel kemény habbá."
            },
            {
                "@type": "HowToStep",
                "text": "A sütőt melegítsd elő 180 C fokra."
            },
            {
                "@type": "HowToStep",
                "text": "Ha a köles megfőtt, vedd le a tűzről."
            },
            {
                "@type": "HowToStep",
                "text": "Keverd bele a citrom reszelt héját."
            },
            {
                "@type": "HowToStep",
                "text": "Mehet bele a méz, a vanília aroma, a fahéj és végül a tojások sárgája."
            },
            {
                "@type": "HowToStep",
                "text": "Keverd össze alaposan."
            },
            {
                "@type": "HowToStep",
                "text": "Most add hozzá a rumba áztatott mazsolát vagy vörös áfonyát."
            },
            {
                "@type": "HowToStep",
                "text": "Óvatosan, hogy a hab ne törjön össze, keverd hozzá a kemény habbá vert tojásfehérjéket."
            },
            {
                "@type": "HowToStep",
                "text": "Egy tepsit kenj ki hideg vajjal, majd szórd meg zsemlemorzsával."
            },
            {
                "@type": "HowToStep",
                "text": "Mehet bele a habos tészta."
            },
            {
                "@type": "HowToStep",
                "text": "Tedd a sütőbe."
            },
            {
                "@type": "HowToStep",
                "text": "30 perc alatt készre sül."
            }
        ],
        "prepTime": "PT0S",
        "cookTime": "PT30M",
        "recipeYield": "4-6",
