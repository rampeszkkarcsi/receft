        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A margarint a cukorral és a vaníliás cukorral habosra keverjük."
            },
            {
                "@type": "HowToStep",
                "text": "Egyenként hozzáadjuk a tojásokat."
            },
            {
                "@type": "HowToStep",
                "text": "Belekeverjük a lisztet, a sütőport, a fahéjat, majd felváltva a vörösbort."
            },
            {
                "@type": "HowToStep",
                "text": "Végül hozzáforgatjuk a durvára vágott diót és az étcsokoládét."
            },
            {
                "@type": "HowToStep",
                "text": "A masszát vastagon kivajazott kuglófformába öntjük."
            },
            {
                "@type": "HowToStep",
                "text": "180 °C-on kb. 1 órán át sütjük."
            }
