        "name": "Sajtos csirke",
        "recipeIngredient": [
            "4 csirkecomb",
            "1 nagy fej vöröshagyma",
            "3 gerezd fokhagyma",
            "2 dl tejföl",
            "2 ek. olaj",
            "1 púpozott ek. liszt",
            "1 púpozott tk. pirospaprika",
            "1 mokkáskanál őrölt bors",
            "só",
            "reszelt sajt"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A csirkecombokat megsózom, a fokhagymát pépesre, a vöröshagymát karikákra vágom."
            },
            {
                "@type": "HowToStep",
                "text": "A tejfölbe belekeverem az olajat,"
            },
            {
                "@type": "HowToStep",
                "text": "a combokat egy tálba teszem."
            },
            {
                "@type": "HowToStep",
                "text": "A lisztet elkeverem a pirospaprikával, sóval, és borssal, majd rászórom a húsra."
            },
            {
                "@type": "HowToStep",
                "text": "Rászórom a hagymát és sajtot."
            },
            {
                "@type": "HowToStep",
                "text": "Az olajos fokhagymás tejfölt öntöm a tetejébe."
            },
            {
                "@type": "HowToStep",
                "text": "Lefedve hideg sütőben kezdem sütni."
            },
            {
                "@type": "HowToStep",
                "text": "A végén leveszem a fedőt és erősebb lángon megpirítom a tetejét."
            },
            {
                "@type": "HowToStep",
                "text": "2 óráig sütöm (mikróban 20 perc, teljesítménytől függően)."
            }
        ],
