[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Bukta",
        "recipeIngredient": [
            "1/2 kg liszt",
            "3 dkg élesztő",
            "5 dkg cukor",
            "só",
            "2 tojássárgája",
            "3 dl tej",
            "6 dkg margarin",
            "lekvár"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "1 dl langyos tejjel az élesztőt felfuttatjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A tojássárgáját a cukorral elkeverjük, majd hozzáöntjük a maradék 2 dl langyos tejet."
            },
            {
                "@type": "HowToStep",
                "text": "A liszt közepébe öntjük a tojásos keveréket és a felfuttatott élesztőt. Jól kidolgozzuk, hogy hólyagos legyen, majd hozzákeverjük az olvasztott margarint."
            },
            {
                "@type": "HowToStep",
                "text": "Langyos helyen kelesztjük."
            },
            {
                "@type": "HowToStep",
                "text": "Lisztezett deszkára borítjuk, kb. 1 cm vastagra kinyújtjuk. 8–10 cm-es négyzetekre vágjuk, a közepükbe lekvárt teszünk, majd összecsomagoljuk."
            },
            {
                "@type": "HowToStep",
                "text": "A tetejét zsírral megkenjük."
            },
            {
                "@type": "HowToStep",
                "text": "Fél órát pihentetjük."
            },
            {
                "@type": "HowToStep",
                "text": "Közepesen forró sütőben megsütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Csak tálaláskor szedjük szét, a tetejét porcukorral meghintjük."
            }
        ],
