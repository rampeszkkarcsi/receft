[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Bodzaszörp",
        "recipeIngredient": [
            "13 kg cukor",
            "41 6 liter víz",
            "12-15 bodzavirágzat",
            "3 citrom",
            "10 dkg citromsav vagy citrompótló",
            "Kevés Na-benzoát"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Elsó nap a vízből és a cukorból sűrű sziru-pot fözünk."
            },
            {
                "@type": "HowToStep",
                "text": "Másnap elkeverjük benne a citromsavat, és kettéöntjük két 5 literes befőttesüvegbe."
            },
            {
                "@type": "HowToStep",
                "text": "Beletesszük a karikára vágott citromot, a bodzavirágokat, és kistányérral lefedjük az üvegeket."
            },
            {
                "@type": "HowToStep",
                "text": "Hűvös helyre tesszük."
            },
            {
                "@type": "HowToStep",
                "text": "Naponta egyszer jól felkeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "4-5 napig hagyjuk így érni."
            },
            {
                "@type": "HowToStep",
                "text": "Ezután leszűrjük, 1 kiskanál nátrium-benzoátot feloldunk kevés forró vizben, és a szörpbe keverjük."
            },
            {
                "@type": "HowToStep",
                "text": "Üvegekbe töltjük, és higitva fogyasztjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Ha igazi bodzaizre vágysz, érdemes időt szárni a valódi bodzaszörp exeszitésére."
            },
            {
                "@type": "HowToStep",
                "text": "Ha esetleg elfeledkeznél egy-egy üveg szörpről, ne aggódj, 4-5 év után még finomabb, muskotályos izt kap"
            }
        ],
