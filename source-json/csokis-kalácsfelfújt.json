        "name": "Csokis kalácsfelfújt",
        "recipeIngredient": [
            "30dkg szikkadt kalács",
            "3-4 ek nutella",
            "4dl tej",
            "3dl tejszín",
            "3dkg vaj",
            "10dkg cukor",
            "2 tojás",
            "2 sárgája",
            "10dkg tejcsoki"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Kalácsot felszeletelni, minden 2. Szeletet nutellaval megkenni vastagon, szendvicseket készíteni, ezeket 2cmes kockákra vágni."
            },
            {
                "@type": "HowToStep",
                "text": "Tej meg tejszín lábosba melegít"
            },
            {
                "@type": "HowToStep",
                "text": "Tojás, sárgája, cukor összekeverjük"
            },
            {
                "@type": "HowToStep",
                "text": "Meleg tejet apránként hozzá a cukros tojashoz, beleforgatni a kalacskockakat, 5-10p alatt magukba szívják."
            },
            {
                "@type": "HowToStep",
                "text": "30x20cm tepsit kivajazni, bele a kalács, közé csokidarabkak, tetejére vajat morzsolni."
            },
            {
                "@type": "HowToStep",
                "text": "175° 45 percig sütni"
            }
        ],
