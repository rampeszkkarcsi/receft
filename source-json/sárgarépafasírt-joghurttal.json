        "@type": "Recipe",
        "name": "Sárgarépafasírt joghurttal",
        "recipeIngredient": [
            "60 dkg sárgarépa",
            "1 csokor petrezselyem",
            "3 db tojás",
            "só",
            "zsemlemorzsa",
            "4 dl joghurt",
            "1 ek. római kömény",
            "2 ek. olívaolaj",
            "fél citrom",
            "1 dl napraforgóolaj"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A sárgarépát megtisztítjuk, lereszeljük, kissé kinyomkodjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Összekeverjük a tojással, a finomra vágott petrezselyemmel."
            },
            {
                "@type": "HowToStep",
                "text": "Ízesítjük sóval, és annyi morzsát adunk hozzá, hogy formázható legyen."
            },
            {
                "@type": "HowToStep",
                "text": "Kis pogácsákat készítünk és kevés napraforgóolajon mindkét oldalán megsütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A joghurtot a citrom levével, római köménnyel és olívaolajjal elkeverjük, majd a kisült répapogácsák mellé kínáljuk, mártogatósnak."
            }
        ],
