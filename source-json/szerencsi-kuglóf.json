        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Szerencsi kuglóf",
        "recipeIngredient": [
            "20 dkg ét tortabevonó",
            "20 dkg liszt",
            "5 dkg kakaópor",
            "5 dkg cukor",
            "5 dkg mazsola (elhagyható)",
            "10 dkg vaj",
            "3 tojás",
            "1 dl tej",
            "2 dkg élesztő"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Az élesztőből langyos tejjel, kevés liszttel és egy csipet cukorral kovászt készítünk."
            },
            {
                "@type": "HowToStep",
                "text": "A vajat a cukorral jól kikeverjük, majd összedolgozzuk a liszttel és a 3 tojással."
            },
            {
                "@type": "HowToStep",
                "text": "Végül hozzáadjuk az elkészített kovászt."
            },
            {
                "@type": "HowToStep",
                "text": "A tésztát két részre osztjuk:"
            },
            {
                "@type": "HowToStep",
                "text": "az egyik felébe belekeverjük a kakaóport,"
            },
            {
                "@type": "HowToStep",
                "text": "a másik felébe a mazsolát."
            },
            {
                "@type": "HowToStep",
                "text": "Kivajazott, lisztezett kuglófformába öntjük."
            },
            {
                "@type": "HowToStep",
                "text": "Ha megkelt, 220 °C-os sütőben kb. 45 percig sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A kihűlt kuglóf tetejét olvasztott tortabevonóval bevonjuk."
            }
        ],
