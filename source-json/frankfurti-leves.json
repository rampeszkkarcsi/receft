        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A finomra vágott hagymát olajon megpirítjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Hozzátesszük a zúzott fokhagymát és a felkockázott krumplit."
            },
            {
                "@type": "HowToStep",
                "text": "Sózzuk, borsozzuk, meghintjük majorannával és petrezselyemmel."
            },
            {
                "@type": "HowToStep",
                "text": "Felengedjük vízzel."
            },
            {
                "@type": "HowToStep",
                "text": "Mikor a krumpli félig megfőtt, hozzáadjuk a vékony csíkokra vágott kelkáposztát."
            },
            {
                "@type": "HowToStep",
                "text": "Ha már megfőtt, rántást készítünk, megszórjuk piros paprikával, és levesbe sűrítjük."
            },
            {
                "@type": "HowToStep",
                "text": "Virslikarikákat teszünk bele, ha kész, tejfölt is belekeverjük."
            }
        ],
