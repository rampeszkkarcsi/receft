        "@type": "Recipe",
        "name": "PISZTRÁNG PULISZKÁVAL GÖNGYÖLT SONKÁBA",
        "recipeIngredient": [
            "8 darab bőr nélküli pisztrángfilé (kb. 80 dkg)",
            "8 szelet vékony, szárított sonka (pl. fekete-erdei)",
            "5 dkg vaj",
            "olaj",
            "3 szál friss kakukkfű",
            "A puliszkához",
            "só",
            "20 dkg kukoricadara",
            "5 dkg vaj",
            "3 szál friss kakukkfű",
            "10 dkg dió"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A pisztrángfiléket csipesszel kiszálkázzuk, majd mindegyiket 1-1 szelet sonkára fektetjük."
            },
            {
                "@type": "HowToStep",
                "text": "Megkenjük szoba-hőmérsékletű vajjal."
            },
            {
                "@type": "HowToStep",
                "text": "Szorosan feltekerjük, zsineggel megkötözzük."
            },
            {
                "@type": "HowToStep",
                "text": "Serpenyőben, kevés olajon, folyamatosan forgatva, a kakukkfüvet mellétéve kb. 20 perc alatt megsütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A puliszkához négyszeres mennyiségű vizet forralunk, megsózzuk, beleöntjük a kukoricadarát, és habverővel kevergetve, kis lángon megfőzzük."
            },
            {
                "@type": "HowToStep",
                "text": "A tűzről lehúzva belekeverjük a vajat, majd tálaláskor megszórjuk kakukkfűlevéllel és dióval."
            },
            {
                "@type": "HowToStep",
                "text": "A pisztráng mellé kínáljuk."
            }
        ],
