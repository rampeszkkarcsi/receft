            "1 cs sütőpor",
            "Krém",
            "20 dkg cukor",
            "20 dkg vaj",
            "rum",
            "puncsos pudingpor + 4 dl tej (cukor nélkül megfőzni)",
            "epres pudingpor + 4 dl tej (cukor nélkül megfőzni)",
            "Csokibevonat",
            "10 dkg vaj",
            "10 dkg cukor",
            "1 ek tej",
            "2 ek kakaópor"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A tojásokat, cukrot az olajjal és a vízzel habosra verjük (kb. 15 perc robotgéppel), majd hozzáadjuk a sütőport és a lisztet."
            },
            {
                "@type": "HowToStep",
                "text": "A masszát kétfelé öntjük, az egyik felébe 2 ek kakaóport teszünk."
            },
            {
                "@type": "HowToStep",
                "text": "Kikent őzgerincformában kisütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A cukrot a vajjal jól kikeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "Ha a pudingok kihűltek, a vajas krémmel összekeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "Az őzgerincből kiborított tésztát bordánként felszeleteljük, és a krémmel (felváltva a kétféle ízt) megtöltjük."
            },
            {
                "@type": "HowToStep",
                "text": "(1 barna - 1 sárga tészta!)"
            },
            {
                "@type": "HowToStep",
                "text": "Az egészet csokibevonattal bekenjük, majd ferdén felszeleteljük."
            }
        ],
