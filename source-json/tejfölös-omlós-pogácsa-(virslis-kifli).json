        "@type": "Recipe",
        "name": "Tejfölös omlós pogácsa (Virslis kifli)",
        "recipeIngredient": [
            "50-60 dkg liszt",
            "1 evőkanál só",
            "25 dkg margarin vagy vaj",
            "2 db tojássárgája",
            "5 dkg élesztő",
            "2 dl tejföl",
            "2 dl tej",
            "20 dkg reszelt sajt (a tetejére)"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "2 dl tejben az élesztőt felfuttatni (1-2 dkg cukor a tejbe)."
            },
            {
                "@type": "HowToStep",
                "text": "A margarint elmorzsolni a liszttel, hozzáadni az élesztőt és a többi anyagot."
            },
            {
                "@type": "HowToStep",
                "text": "Hosszú gyenge rétestészta állagút kapjunk, amit fél óráig pihentetünk."
            },
            {
                "@type": "HowToStep",
                "text": "Utána kinyújtjuk és háromszor hajtogatjuk, mint a vajas tésztát szokás, ezt még kétszer ismételjük 20 percenként."
            },
            {
                "@type": "HowToStep",
                "text": "Harmadszorra is kinyújtjuk és kiszaggatjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Utána a tepsibe pihen és sül."
            }
        ],
