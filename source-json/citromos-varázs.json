        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A tejfölt a cukorral és a vaníliás cukorral habosra keverjük, majd belekeverjük a citrom levét és reszelt héját."
            },
            {
                "@type": "HowToStep",
                "text": "A tejszínt kemény habbá verjük a habfixálóval, majd óvatosan a citromos krémhez keverjük."
            },
            {
                "@type": "HowToStep",
                "text": "Egy jénai tál alját kirakjuk babapiskótával, rákenjük a krém felét, majd ismét egy sor babapiskóta következik, végül a krém másik fele."
            },
            {
                "@type": "HowToStep",
                "text": "Egy éjszakára hűtőbe tesszük."
            }
        ],
