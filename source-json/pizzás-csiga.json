        "name": "Pizzás csiga",
        "recipeIngredient": [
            "2.8 dkg élesztő",
            "50 dkg liszt",
            "1 púpos evőkanál tejföl",
            "1 evőkanál olaj",
            "2.4 dl víz",
            "2 kiskanál só",
            "1 kiskanál cukor",
            "pizzakrém",
            "kb. 15 dkg gépsonka",
            "10-15 dkg reszelt sajt"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A hozzávalókat összegyúrjuk, vagy dagasztógépbe tesszük, ha megkelt, téglalapra nyújtjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Ráteszünk a pizza krémet, a sonkaszeleteket, és a reszelt sajt 3/4-ét."
            },
            {
                "@type": "HowToStep",
                "text": "Feltekerjük mint a rétest, és 2 ujjnyi vastagra vágjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A korongokat tepsire helyezzük, és sajttal megszórjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Előmelegített sütőben 200 fokon 20 percig sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Megjegyzés: Én nem csak gépsonkát, hanem apróra szelt bacont is szórtam rá és füstölt sajtot is használtam."
            },
            {
                "@type": "HowToStep",
                "text": "Én a tésztából 2 nagy téglalapot készítettem. (így nem volt olyan vastag a tészta )"
            }
        ],
