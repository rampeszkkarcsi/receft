            "1 tk szódabikarbóna",
            "1/2 tk só",
            "1 csomag vaníliás cukor",
            "2 tojás",
            "1/2 tk fahéj",
            "kevés tej (ha szükséges)",
            "étcsokoládé"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A vajat mikróban felolvasztjuk és összekeverjük a tojásokkal."
            },
            {
                "@type": "HowToStep",
                "text": "Külön összekeverjük a lisztet, cukrot, sütőport, szódabikarbónát, sót, vaníliás cukrot és fahéjat."
            },
            {
                "@type": "HowToStep",
                "text": "A két keveréket összeöntjük."
            },
            {
                "@type": "HowToStep",
                "text": "Belekeverjük az apróra tört étcsokoládét."
            },
            {
                "@type": "HowToStep",
                "text": "Kézzel gyúrható tésztát készítünk. Ha túl sűrű, kevés tejjel lazítjuk."
            },
            {
                "@type": "HowToStep",
                "text": "3–4 cm átmérőjű golyókat formázunk."
            },
            {
                "@type": "HowToStep",
                "text": "200 °C-ra előmelegített sütőben 7-8 perc alatt megsütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Kihűlve finom, ropogós cookie lesz."
            }
        ],
