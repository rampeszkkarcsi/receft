        "name": "Rakott töltött palacsinta",
        "recipeIngredient": [
            "10 vastagabb palacsinta",
            "20 dkg főtt (legjobb: füstölt) hús",
            "15 dkg főtt-füstölt sonka",
            "1 nagyobb doboz tejföl",
            "1 tojás",
            "20 dkg sajt"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A főtt húst + sonkát apróra vágjuk és összekeverjük fél doboz tejföllel."
            },
            {
                "@type": "HowToStep",
                "text": "A sajtot lereszeljük, 1/3-át félretesszük a tetejére szórásához."
            },
            {
                "@type": "HowToStep",
                "text": "Egy jénait kivajazunk."
            },
            {
                "@type": "HowToStep",
                "text": "A tejföl másik felét összekeverjük a tojással, sózzuk."
            },
            {
                "@type": "HowToStep",
                "text": "A palacsintákat megtöltjük a húsos cuccal, majd megszórjuk reszelt sajttal és feltekerjük."
            },
            {
                "@type": "HowToStep",
                "text": "A megtöltött palacsintákat a tepsibe helyezzük."
            },
            {
                "@type": "HowToStep",
                "text": "Végül a tejföl-tojás keverékkel leöntjük, a félretett sajttal megszórjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Közepes lángon sütjük, míg a sajt meg nem pirul."
            }
        ],
