        "name": "Muszala",
        "recipeIngredient": [
            "0.5 kg padlizsán",
            "0.5 kg burgonya",
            "0.8 kg darált hús",
            "2 vöröshagyma",
            "2 paradicsom",
            "1 paprika",
            "6 gerezd fokhagyma",
            "kb. 3 dl sűrített paradicsom",
            "fahéj",
            "oregánó",
            "babérlevél",
            "szegfűszeg",
            "só",
            "bors",
            "Mártáshoz:",
            "5 dkg vaj",
            "liszt",
            "tej",
            "1 tojás",
            "só",
            "szerecsendió",
            "reszelt füstölt sajt"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A padlizsánokat 1 cm-es szeletekre vágva sütőben megsütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A krumplit felkockázzuk, majd megfőzzük."
            },
            {
                "@type": "HowToStep",
                "text": "Az apróra szelt hagymát olajon megdinszteljük, hozzáadjuk a húst és megpirítjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Közben a sót, borsot, fahéjat, oregánót, babérlevelet, szegfűszeget és a zúzott fokhagymát is belekeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "Ha a hús kezd átsülni, hozzáadjuk a felaprított paradicsomot, paprikát, és a paradicsompürét, és zsírjára sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Egy edényben megolvasztjuk a vajat, és hozzáadjuk a lisztet, a tejet és a tojást."
            },
            {
                "@type": "HowToStep",
                "text": "Levesszük a tűzről, sózzuk, hozzáadjuk a szerecsendiót, reszelt sajtot."
            },
            {
                "@type": "HowToStep",
                "text": "Rétegek: padlizsán, hús, krumpli, mártás."
            },
            {
                "@type": "HowToStep",
                "text": "Előmelegített sütőben közepes lángon kb. 25 perc."
            }
        ],
