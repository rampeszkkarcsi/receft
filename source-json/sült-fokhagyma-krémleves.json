        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Süsd a fokhagymát félbe vágva, olívaolajjal megöntözve 180°C-on 20-25 percig, majd hűtsd le, szedd le a héját."
            },
            {
                "@type": "HowToStep",
                "text": "Egy lábasban dinszteld az apróra vágott hagymát, majd add hozzá a sült fokhagymát."
            },
            {
                "@type": "HowToStep",
                "text": "Öntsd fel kb. 8 dl zöldség alaplével, sózd, borsozd."
            },
            {
                "@type": "HowToStep",
                "text": "Felforralni, puhára főzni."
            },
            {
                "@type": "HowToStep",
                "text": "Botmixerrel pürésítsd, tejszínt önteni bele, és még egyszer felforralni."
            },
            {
                "@type": "HowToStep",
                "text": "Kenyérrel tálalni."
            }
        ],
