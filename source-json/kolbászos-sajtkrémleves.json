        "name": "Kolbászos sajtkrémleves",
        "recipeIngredient": [
            "2 szál újhagyma",
            "kevés olaj",
            "35 dkg érlelt, félig lágy sajt",
            "1-1 szál lestyán és rozmaring",
            "5 dl zöldségleves",
            "1 ek. étkezési keményítő",
            "2 dl magas zsírtartalmú tejszín",
            "10 dkg füstölt szárazkolbász"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A felkarikázott újhagymát kevés olajon megpirítjuk, rátesszük a kockára vágott sajtot, a finomra vágott lestyánt és rozmaringot, majd felengedjük a zöldséglevessel."
            },
            {
                "@type": "HowToStep",
                "text": "Addig főzzük, amíg a sajt elolvad, aztán összeturmixoljuk."
            },
            {
                "@type": "HowToStep",
                "text": "Visszatesszük a tűzre, és a kevés vízzel elkevert étkezési keményítővel besűrítjük."
            },
            {
                "@type": "HowToStep",
                "text": "Hozzáadjuk a tejszínt, sózzuk, borsozzuk."
            },
            {
                "@type": "HowToStep",
                "text": "A felkarikázott kolbászt egy serpenyőben a vajon megpirítjuk, és tálaláskor a leves tetejére tesszük."
            }
        ],
