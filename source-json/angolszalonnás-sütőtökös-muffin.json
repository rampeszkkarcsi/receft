        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Helyezzünk 12 papírkapszlit a muffinformába."
            },
            {
                "@type": "HowToStep",
                "text": "A sütőt melegítsük elő 180 °C-ra."
            },
            {
                "@type": "HowToStep",
                "text": "Az angolszalonnát vágjuk apró kockákra, a rozmaringleveleket tépkedjük le a szárról, késsel vágjuk apróra."
            },
            {
                "@type": "HowToStep",
                "text": "A tészta összes hozzávalóját tegyük keverőtálba, alaposan dolgozzuk össze, majd osszuk szét a formákba."
            },
            {
                "@type": "HowToStep",
                "text": "30-35 perc alatt süssük készre."
            }
        ],
