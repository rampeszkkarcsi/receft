        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "ALMÁS, ZELLERES, KÉKSAJTOS SALÁTA DIÓVAL",
        "recipeIngredient": [
            "50 dkg szárzeller (angolzeller)",
            "50 dkg alma",
            "15 dkg kéksajt",
            "15 dkg dióbél",
            "5 dkg aszalt vörös áfonya",
            "1 citrom leve",
            "1 gerezd fokhagyma",
            "15 dkg natúr joghurt"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A zellerszárat 3-4 mm vastag szeletekre vágjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A megmosott almát kicsumázzuk, felkockázzuk, a zellerrel együtt tálba tesszük."
            },
            {
                "@type": "HowToStep",
                "text": "A sajtot apróra vágjuk, majd a dióval és vörös áfonyával együtt a zelleres keverékhez adjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Meglocsoljuk a citromlével."
            },
            {
                "@type": "HowToStep",
                "text": "A fokhagymát megpucoljuk, lereszeljük, elkeverjük a joghurttal."
            },
            {
                "@type": "HowToStep",
                "text": "Kissé megsózzuk, a salátára öntjük."
            },
            {
                "@type": "HowToStep",
                "text": "Önmagában is finom, de kiváló köret lehet bármilyen sült hús mellé."
            }
        ],
