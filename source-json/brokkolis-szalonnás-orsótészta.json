        "name": "Brokkolis-szalonnás orsótészta",
        "recipeIngredient": [
            "30 dkg kolozsvári szalonna",
            "3 evőkanál olívaolaj",
            "3 gerezd fokhagyma",
            "só, frissen őrölt bors",
            "40 dkg brokkoli",
            "50 dkg orsótészta (fussili)"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Vágjuk kockákra a szalonnát, az olívaolajon süssük ropogósra, a sütési idő felénél adjuk hozzá az aprított fokhagymát."
            },
            {
                "@type": "HowToStep",
                "text": "Borsozzuk, sózni nem szükséges, a szalonna sós."
            },
            {
                "@type": "HowToStep",
                "text": "Szedjük rózsákra a brokkolit."
            },
            {
                "@type": "HowToStep",
                "text": "Nagy fazékban forraljunk vizet, amikor felforrt, sózzuk."
            },
            {
                "@type": "HowToStep",
                "text": "A brokkolit a tésztával együtt tegyük a vízbe, 10-11 perc alatt főzzük a tésztát puhára, ennyi idő alatt a brokkoli is bőven megfő."
            },
            {
                "@type": "HowToStep",
                "text": "Szűrjük le, szedjük a szalonnára, keverjük el, és azonnal tálaljuk."
            }
        ],
