        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A paprikákat félbevágjuk, kimagozzuk. besózzuk, megfordítjuk, és legalább 20 percig állni hagyjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A túróba reszeljük a kecskesajtot, és belekeverjük az aprított snidlinggel együtt."
            },
            {
                "@type": "HowToStep",
                "text": "Sóval, őrölt köménnyel ízesítjük, és összekeverjük a tojásokkal."
            },
            {
                "@type": "HowToStep",
                "text": "A tölteléket a paprikákba töltjük, majd kiolajozott tepsibe tesszük, és 180 °C-os sütőben 10-12 percig sütjük."
            }
