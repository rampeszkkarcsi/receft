        "name": "Kecskesajtos, túrós töltött paprika",
        "recipeIngredient": [
            "8 db paprika (tv paprika vagy kaliforniai)",
            "só, őrölt kömény",
            "30 dkg túró",
            "15 dkg kecskesajt",
            "1 csokor friss snidling",
            "2 tojás"
