        "name": "Mozzarellás-paradicsomos húspástétom",
        "recipeIngredient": [
            "60 dkg marhafartő",
            "10 dkg vöröshagyma (aprítva)",
            "2 gerezd fokhagyma",
            "1 marék bazsalikomlevél",
            "2 szál kakukkfű",
            "só, bors",
            "1 ek. olívaolaj",
            "20 dkg mozzarella",
            "20 dkg paradicsom"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A húst ledaráljuk, majd hozzáadjuk az apróra vágott vöröshagymát, fokhagymát, a bazsalikom felét, a kakukkfüvet. Sózzuk, borsozzuk, jót összedolgozzuk."
            },
            {
                "@type": "HowToStep",
                "text": "Egy olívaolajjal kikent tűzálló tálba simítjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A tetejére helyezzük a karikára vágott mozzarellát, a vastag szeletekre vágott paradicsomot, megszórjuk a maradék bazsalikomlevéllel, sózzuk, borsozzuk."
            },
            {
                "@type": "HowToStep",
                "text": "180 °C-os sütőben 20-25 percig sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Pirítóssal tálaljuk."
            }
        ],
