        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A tésztát szobahőmérsékleten kiolvasztjuk, majd lisztezett deszkán kinyújtjuk kb. fél centi vastag téglalapra."
            },
            {
                "@type": "HowToStep",
                "text": "Villával felvert tojással vékonyan megkenjük a tetejét, majd megszórjuk cukorral elkevert dióval, tökmaggal."
            },
            {
                "@type": "HowToStep",
                "text": "A bejglihez hasonlóan óvatosan föltekerjük és körülbelül egy centi széles szeletekre felvágjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Vajjal kikent sütőlapra rakjuk, és a tetejét tojással megkenjük."
            },
            {
                "@type": "HowToStep",
                "text": "Közepes hőmérsékletű sütőben készre sütjük."
            }
        ],
