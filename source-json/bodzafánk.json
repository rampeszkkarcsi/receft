[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Bodzafánk",
        "recipeIngredient": [
            "1/2 liter tej",
            "5 dkg porcukor",
            "1,5 dkg élesztő",
            "2 tojás",
            "1 csipet só",
            "40 dkg sima liszt",
            "12-15 bodzavirágzat"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Egy kevés tejben elkeverem az élesztőt és a porcukrot."
            },
            {
                "@type": "HowToStep",
                "text": "Hozzáöntöm a többi tejhez, elhabarom benne a két tojást."
            },
            {
                "@type": "HowToStep",
                "text": "Kevergetés közben, apránként öntöm hozzá a sóval elkevert liszthez."
            },
            {
                "@type": "HowToStep",
                "text": "Ebbe morzsolom bele a bodzavirágot."
            },
            {
                "@type": "HowToStep",
                "text": "A tésztát másfél óráig kelesztem."
            },
            {
                "@type": "HowToStep",
                "text": "Tükörtojássütőben olajat melegítek, ebbe szaggatom bele a tésztát evőkanállal."
            },
            {
                "@type": "HowToStep",
                "text": "Lassú tűzön süssük, hogy a belseje ne maradjon nyers."
            },
            {
                "@type": "HowToStep",
                "text": "Miután mindkét oldala pirosra sült, lecsepegtetem, és még melegen megszórom fahéjas porcukorral."
            }
        ],
