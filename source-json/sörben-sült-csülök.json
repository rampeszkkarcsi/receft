        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A hagymát és fokhagymát olajban megdinszteljük."
            },
            {
                "@type": "HowToStep",
                "text": "A csülköt kockákra vágva átsütjük az olajban, rászórjuk a lisztet, sót, borsot, szerecsendiót, babérlevelet, öntjük a sört és ecetet."
            },
            {
                "@type": "HowToStep",
                "text": "Fedő alatt, majd fedő nélkül sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A lisztet az utolsó fél, 1 órában elég rászórni, átkeverni (amikor kuktában előfőzzük)."
            },
            {
                "@type": "HowToStep",
                "text": "kb. 2-2½ óra."
            }
        ],
