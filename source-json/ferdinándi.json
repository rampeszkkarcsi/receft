[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Ferdinándi",
        "recipeIngredient": [
            "Tészta",
            "35 dkg liszt",
            "1 evőkanál cukor",
            "1 mokkáskanál só",
            "2 diónyi margarin",
            "4 dkg tejben felfuttatott élesztő (kb. 2 dl tej)",
            "3 tojás sárgája",
            "Töltelék",
            "10 dkg mazsola (megmosva, beáztatva)",
            "15 dkg margarin",
            "15 dkg porcukor",
            "vaníliás cukor"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Retestészta keménységű tésztát készítünk, majd kb. fél órát kelesztjük."
            },
            {
                "@type": "HowToStep",
                "text": "A margarint a porcukorral habosra keverjük."
            },
            {
                "@type": "HowToStep",
                "text": "A tésztát késfok vastagságúra nyújtjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Megkenjük a margarinos porcukorral."
            },
            {
                "@type": "HowToStep",
                "text": "Rászórjuk a mazsolát."
            },
            {
                "@type": "HowToStep",
                "text": "Feltekerjük, mint a bejglit."
            },
            {
                "@type": "HowToStep",
                "text": "Kétujjnyi szeletekre vágjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Margarinozott tepsibe rakjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Még kb. 1 órát kelesztjük. (amíg a tepsi megtelik)"
            },
            {
                "@type": "HowToStep",
                "text": "175-200 °C-on sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Amikor félig megsült, 1 kávétejszín + cukor + vaníliás cukor keverékével meglocsoljuk"
            },
            {
                "@type": "HowToStep",
                "text": "még forrón kiborítjuk a tepsiből"
            }
        ],
