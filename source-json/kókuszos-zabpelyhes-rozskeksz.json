        "@type": "Recipe",
        "name": "Kókuszos zabpelyhes rozskeksz",
        "recipeIngredient": [
            "10 dkg rozsliszt",
            "6 dkg zabpehely",
            "4 dkg kókuszreszelék",
            "7 dkg cukor",
            "1/2 kk szódabikarbóna",
            "1/2 kk sütőpor",
            "10 dkg olvadt vaj",
            "1 egész tojás",
            "csipet só"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "Kivesszük a sütőrácsot, és begyújtjuk a sütőt (4-5-ös fokozat)."
            },
            {
                "@type": "HowToStep",
                "text": "A sütőtepsit kibéleljük sütőpapírral."
            },
            {
                "@type": "HowToStep",
                "text": "Az olvadt vajba belekeverjük a cukrot, a csipet sót, majd a tojással habosra keverjük."
            },
            {
                "@type": "HowToStep",
                "text": "A lisztet, a zabpelyhet, a kókuszreszeléket, a szódabikarbónát és a sütőport összekeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "A lisztes keverékbe belekeverjük a vajas keveréket."
            },
            {
                "@type": "HowToStep",
                "text": "Diónyi golyókat formázunk (kb. evőkanálnyiakat), és 1 cm magas koronggá lapítjuk."
            },
            {
                "@type": "HowToStep",
                "text": "Előmelegített sütőben sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Áttesszük a sütőrácsra kihűlni, ott fog megkeményedni."
            },
            {
                "@type": "HowToStep",
                "text": "Sütési hőfok: 180°C"
            }
        ],
