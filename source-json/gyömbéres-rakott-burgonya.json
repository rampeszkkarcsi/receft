[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "GYÖMBÉRES RAKOTT BURGONYA",
        "recipeIngredient": [
            "1 kg burgonya",
            "5 dl tej",
            "5 evőkanál finomliszt",
            "20 dkg gomba",
            "10 dkg sonka",
            "5 dkg vaj",
            "1 fej vöröshagyma",
            "2-2 evőkanál zsemlemorzsa és olaj",
            "1 diónyi friss gyömbér (vagy 1 evőkanál gyömbérpor)",
            "1 csokor petrezselyemzöld",
            "ízlés szerint só"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "a burgonyát meghámozom és hasábokra vágom."
            },
            {
                "@type": "HowToStep",
                "text": "Sós vízben megfőzöm, lecsöpögtetem."
            },
            {
                "@type": "HowToStep",
                "text": "A gyömbért meghámozom, megreszelem, a petrezselyemzöldet finomra vágom."
            },
            {
                "@type": "HowToStep",
                "text": "A sonkát egészen vékony csíkozom."
            },
            {
                "@type": "HowToStep",
                "text": "A gombát vékony szeletekre, a hagymát finomra vágom."
            },
            {
                "@type": "HowToStep",
                "text": "A vajat a liszttel habzásig forrósítom, felöntöm a tejjel, és kevergetve sűrű mártássá főzöm."
            },
            {
                "@type": "HowToStep",
                "text": "Tűzálló tálat kikenek egy evőkanál olajjal."
            },
            {
                "@type": "HowToStep",
                "text": "a mártást hagymával, gombával, gyömbérrel és sóval összekeverem."
            },
            {
                "@type": "HowToStep",
                "text": "A kikent tepsibe egyenletesen elosztom burgonyát, ráöntöm a mártást, tetejére szórom a sonkacsíkokat, és zsemlemorzsával behintem."
            },
            {
                "@type": "HowToStep",
                "text": "A megmaradt olajjal meglocsolom, és előmelegített sütőben közepes lángon 30 percig sütöm."
            },
            {
                "@type": "HowToStep",
                "text": "fehérjét valamint a finomra vágott zöldfűszereket."
            }
        ],
