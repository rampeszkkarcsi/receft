        "name": "Kókuszos csirke salátával",
        "recipeIngredient": [
            "A húshoz",
            "4 csirkecomb vagy más csirkehús",
            "2 tojás",
            "2 ek. kókuszreszelék",
            "liszt",
            "zsemlemorzsa",
            "só",
            "fehér bors",
            "ételízesítő",
            "olaj",
            "A salátához",
            "2 fej saláta",
            "1 ek. olívaolaj",
            "citrom",
            "15 dkg reszelt sajt"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A combokat félbevágjuk, ízlés szerint fűszerezzük sóval és fehér borssal."
            },
            {
                "@type": "HowToStep",
                "text": "A tojásokat villával felverjük, csipet sóval és kókuszreszelékkel elkeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "A húsokat lisztbe, majd kókuszos tojásba és zsemlemorzsába forgatjuk és bő olajban mindkét oldalukat pirosra sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "A salátákat négybe vágjuk, két-két negyedet tányérokra teszünk, kevés olajat és citromlét csöpögtetünk rá, majd reszelt sajttal megszórjuk."
            },
            {
                "@type": "HowToStep",
                "text": "A salátát a hús mellé köretként tálaljuk."
            }
        ],
