[
    {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": "Őszibarackos tekercs",
        "recipeIngredient": [
            "Tészta",
            "3 tojás",
            "8 dkg cukor",
            "2 dkg kakaópor",
            "1 tk sütőpor",
            "6 dkg liszt",
            "Töltelék",
            "4 dl tejszín",
            "2 csomag vaníliás cukor",
            "20 dkg őszibarack",
            "10 dkg áfonya"
        ],
        "recipeInstructions": [
            {
                "@type": "HowToStep",
                "text": "A tojásfehérjét a cukorral kemény habbá verjük."
            },
            {
                "@type": "HowToStep",
                "text": "A tojássárgáját egyesével hozzákeverjük."
            },
            {
                "@type": "HowToStep",
                "text": "A kakaóporral és sütőporral elkevert lisztet beleforgatjuk a habmasszába."
            },
            {
                "@type": "HowToStep",
                "text": "Sütőpapírral bélelt tepsibe simítjuk, és 200 °C-on 10 percig sütjük."
            },
            {
                "@type": "HowToStep",
                "text": "Konyharuhával letakarva hagyjuk kihűlni."
            },
            {
                "@type": "HowToStep",
                "text": "A tejszínt és a vaníliás cukrot kemény habbá verjük."
            },
            {
                "@type": "HowToStep",
                "text": "A kihűlt piskótát megkenjük a tejszínhabbal."
            },
            {
                "@type": "HowToStep",
                "text": "Az őszibarackot felszeleteljük, az áfonyával együtt elrendezzük a süteményen."
            },
            {
                "@type": "HowToStep",
                "text": "Feltekerjük, hűtőbe tesszük, majd tálalás előtt porcukorral megszórjuk."
            }
        ],
